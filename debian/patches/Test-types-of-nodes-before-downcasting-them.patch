+void tst_QSvgRenderer::oss_fuzz_496327371()
+{
+    // Bad-cast to QSvgMarker from QSvgLine -> Heap-buffer-overflow
+    QImage image(377, 233, QImage::Format_RGB32);
+    QPainter painter(&image);
+    QSvgRenderer renderer(QByteArray(
+            "<svg><line x1=\"4\" id=\"lledr\" marker-end=\"url(#lledr)\" stroke=\"#00f\"/></svg>"));
+    renderer.render(&painter);
+}
+
+void tst_QSvgRenderer::line_as_mask()
+{
+    // Modeled after oss_fuzz_496327371 to test similar problem in QSvgMask, needs UBSAN
+    QImage image(377, 233, QImage::Format_RGB32);
+    QPainter painter(&image);
+    QSvgRenderer renderer(QByteArray(
+            "<svg>"
+            "<defs>"
+            "<line x1=\"4\" id=\"line\"/>"
+            "<mask id=\"mask\" width=\"2\" height=\"2\" mask=\"url(#line)\"/>"
+            "</defs>"
+            "<rect width=\"2\" height=\"2\" mask=\"url(#mask)\"/>"
+            "</svg>"));
+    renderer.render(&painter);
+}
